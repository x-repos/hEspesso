&CONTROL
    calculation      = 'vc-relax'
    prefix           = 'mgco'
    pseudo_dir       = '/home/x/Workspace/espresso/pseudo'
    outdir           = './outdir/'
    restart_mode     = 'from_scratch'
    tprnfor          = .true.
    tstress          = .true.
    etot_conv_thr    = 1.0d-5
    forc_conv_thr    = 1.0d-4
    nstep            = 200
    max_seconds      = 21600
/

&SYSTEM
    ibrav            = 0
    nat              = 16
    ntyp             = 2
    ecutwfc          = 60.0
    ecutrho          = 480.0
    occupations      = 'smearing'
    smearing         = 'cold'
    degauss          = 0.01
    
    nosym            = .true.
    noinv            = .true.
    vdw_corr         = 'DFT-D3'
    dftd3_version    = 4
/

&ELECTRONS
    electron_maxstep = 200
    conv_thr         = 1.0d-9
    mixing_beta      = 0.3
    mixing_mode      = 'plain'
    mixing_ndim      = 12
    diagonalization  = 'david'
    diago_david_ndim = 4
/

&IONS
    ion_dynamics = 'bfgs'
/

&CELL
    cell_dynamics = 'bfgs'
    press_conv_thr = 0.5
/

ATOMIC_SPECIES
  Co  58.9332   Co_pbe_v1.2.uspp.F.UPF
  Mg  24.305    Mg.pbe-n-kjpaw_psl.0.3.0.UPF

