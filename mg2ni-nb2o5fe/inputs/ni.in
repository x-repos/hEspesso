&CONTROL
   calculation      = 'scf'
   restart_mode     = 'from_scratch'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './outdir/'
   prefix           = 'ni'
   etot_conv_thr    = 0.00014
   forc_conv_thr    = 0.0001
   pseudo_dir       = '../pseudo/'
/
&SYSTEM
   ecutwfc          = 60.0
   ecutrho          = 480.0
   occupations      = 'smearing'
   degauss          = 0.01
   smearing         = 'cold'
   nspin            = 2
   starting_magnetization(1) = 0.1
   ntyp             = 1
   nat              = 1
   ibrav            = 0
   vdw_corr         = 'dft-d3'
/
&ELECTRONS
   electron_maxstep = 120
   conv_thr         = 1.2e-09
   mixing_beta      = 0.4
/
&IONS
/
&CELL
/
&FCP
/
&RISM
/
ATOMIC_SPECIES
Ni 58.6934 ni_pbe_v1.4.uspp.F.UPF

K_POINTS automatic
16 16 16  0 0 0

CELL_PARAMETERS angstrom
0.00000000000000 1.76200000000000 1.76200000000000
1.76200000000000 0.00000000000000 1.76200000000000
1.76200000000000 1.76200000000000 0.00000000000000

ATOMIC_POSITIONS angstrom
Ni 0.0000000000 0.0000000000 0.0000000000


HUBBARD (ortho-atomic)
   U Ni-3d 9.0
