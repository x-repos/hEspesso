&CONTROL
   calculation      = 'scf'
   restart_mode     = 'from_scratch'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './outdir/'
   prefix           = 'mgo'
   etot_conv_thr    = 0.00014
   forc_conv_thr    = 0.0001
   pseudo_dir       = '../pseudo/'
/
&SYSTEM
   ecutwfc          = 60.0
   ecutrho          = 480.0
   occupations      = 'smearing'
   degauss          = 0.01
   smearing         = 'cold'
   nspin            = 1
   ntyp             = 2
   nat              = 2
   ibrav            = 0
   vdw_corr         = 'dft-d3'
/
&ELECTRONS
   electron_maxstep = 120
   conv_thr         = 1.2e-09
   mixing_beta      = 0.4
/
&IONS
/
&CELL
/
&FCP
/
&RISM
/
ATOMIC_SPECIES
Mg 24.305 Mg.pbe-n-kjpaw_psl.0.3.0.UPF
O 15.999 O.pbe-n-kjpaw_psl.0.1.UPF

K_POINTS automatic
8 8 8  0 0 0

CELL_PARAMETERS angstrom
0.00000000000000 2.10500000000000 2.10500000000000
2.10500000000000 0.00000000000000 2.10500000000000
2.10500000000000 2.10500000000000 0.00000000000000

ATOMIC_POSITIONS angstrom
Mg 0.0000000000 0.0000000000 0.0000000000  
O 2.1050000000 2.1050000000 2.1050000000  

