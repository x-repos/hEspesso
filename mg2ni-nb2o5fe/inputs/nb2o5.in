&CONTROL
   calculation      = 'vc-relax'
   restart_mode     = 'from_scratch'
   tstress          = .true.
   tprnfor          = .true.
   outdir           = './outdir/'
   prefix           = 'nb2o5'
   etot_conv_thr    = 0.00014
   forc_conv_thr    = 0.0001
   pseudo_dir       = '../pseudo/'
/
&SYSTEM
   ecutwfc          = 60.0
   ecutrho          = 480.0
   occupations      = 'smearing'
   degauss          = 0.01
   smearing         = 'cold'
   nspin            = 1
   ntyp             = 2
   nat              = 14
   ibrav            = 0
   vdw_corr         = 'dft-d3'
/
&ELECTRONS
   electron_maxstep = 120
   conv_thr         = 1.2e-09
   mixing_beta      = 0.4
/
&IONS
   ion_dynamics     = 'bfgs'
/
&CELL
   cell_dynamics    = 'bfgs'
   press_conv_thr   = 0.5
/
&FCP
/
&RISM
/
